      "isDeleted": false,
      "boundElements": [],
      "updated": 1754618076819,
      "link": null,
      "locked": false,
      "text": "Se perguntar se sua personalidade\né diferente das demais, a resposta\nserá \"não\"",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Se perguntar se sua personalidade é diferente das demais, a resposta será \"não\"",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
