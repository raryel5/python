      "updated": 1754618076819,
      "link": null,
      "locked": false,
      "text": "Narcisistas não se dão conta de\ncomo outros percebem sua\npersonalidade",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Narcisistas não se dão conta de como outros percebem sua personalidade",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "WcC4E8Eg07ATAyauVZTse",
      "type": "text",
      "x": 3537.347389034334,
      "y": 2758.5137321070642,
