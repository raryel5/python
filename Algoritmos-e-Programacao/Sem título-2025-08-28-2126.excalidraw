      "type": "text",
      "x": 3190.1327772963514,
      "y": 2541.8005312390674,
      "width": 280.82939743224364,
      "height": 60,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
